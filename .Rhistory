df <- data.frame(
a = 1:3,
b = 4:6,
c = 7:9)
multiply_col <- function(df, column, value = 5) {
df$column * value
}
multiply_col(df, c)
multiply_col <- function(df, column, value = 5) {
df[column] * value
}
multiply_col(df, c)
multiply_col(df, "c")
multiply_col(df, "c", 10)
multiply_col_new <- function(df, column, new_column = "multiplied") {
df %>%
mutate(.data[[new_column]], column * 3)
}
multiply_col_new(df, "c")
