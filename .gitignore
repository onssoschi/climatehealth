# Git Files
!/**/.gitkeep

# R Environment Files
.Rproj.user
.Rhistory
.Rapp.history
.RData
.RDataTmp
.Renviron
..Rcheck
renv

# Common Data Files
*.csv
*.pdf
*.JSON
*.yml
*.yaml
*.toml
*.xlsx
*.xml
*.txt
*.html
*.xls
*.rds

# Test Data Exclusions
!inst/testdata/*

# Workflow exclusions
!.github/worfklows/*
